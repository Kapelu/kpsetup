  local type="$1"
  local msg="$2"
  local icon color text

  case "$type" in
    info)     icon="$ICON_INFO";     color="yellow" ;;
    ok)       icon="$ICON_OK";       color="yellow" ;;
    warn)     icon="$ICON_WARN";     color="yellow" ;;
    error)    icon="$ICON_ERROR";    color="yellow" ;;
    run)      icon="$ICON_RUN";      color="yellow" ;;
    verify)   icon="$ICON_VERIFY";   color="yellow" ;;
    verifail) icon="$ICON_VERIFAIL"; color="yellow" ;;
    *)        icon="";               color="yellow" ;;
  esac

  text="$msg"

  local timestamp
  timestamp="$(datetime time)"

  local console_line="              $timestamp ~${COLOR[$color]} ${text}${COLOR[reset]}"
  local log_line="$timestamp ~${text}"

  {
    flock -x 200

    # consola
    printf "%b%-30s%b\n" "$console_line" >&3

    # log
    if [ -n "$LOG_FILE" ]; then
      printf "%s\n" "$log_line" >>"$LOG_FILE"
    fi
  } 200>/tmp/kapelu.lock
}



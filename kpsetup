#* Crea $USER_HOME/setup.log 
file_log() {
  exec 3>&1
  exec 1>>"$LOG_FILE" 2>&1
  clear >&3
  HEADER="          ===== START -> kapelu $(date '+%Y-%m-%d %H:%M:%S') ====="
  printf "%s\n" "$HEADER"        # рҹ‘ү va al log
  printf "%s\n" "" >&3
  printf "%s\n" "$HEADER" >&3    # рҹ‘ү se ve en pantalla
}
#* datetime: manejo de fecha y hora
datetime() {
  local fecha hora
  fecha="$(date +"%d-%m-%Y")"
  hora="$(date +"%H:%M:%S")"

  case "${1:-full}" in            #    Uso 
    date) printf "%s\n" "$fecha" ;;        # printf "%s\n" "$(datetime date)" 
    time) printf "%s\n" "$hora" ;;         # printf "%s\n" "$(datetime time)"
    *) printf "%s\n" "$fecha - $hora" ;;   # printf "%s\n" "$(datetime)"     
  esac
}
#* elapsed_time: maneja el tiempo de instalaciГіn del script
elapsed_time() {
  local start="$1"
  local elapsed=$((SECONDS - start))

  local horas=$((elapsed / 3600))
  local minutos=$(((elapsed % 3600) / 60))
  local segundos=$((elapsed % 60))

  printf "%dh:%dm:%ds" "$horas" "$minutos" "$segundos"
}

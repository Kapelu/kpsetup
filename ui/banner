print_banner() {
  local msg="$1"
  printf "%b\n" "${COLOR[yellow]}════════════════════════════════════════════════════${COLOR[reset]}"
  printf "%b\n" "$msg"
  printf "%b\n" "${COLOR[yellow]}════════════════════════════════════════════════════${COLOR[reset]}"
  printf "\n"
}